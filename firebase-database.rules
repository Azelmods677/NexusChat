{
  "rules": {
    // Users node
    "users": {
      "$userId": {
        // Anyone authenticated can read user profiles
        ".read": "auth != null",
        
        // Only the user can write their own profile
        ".write": "auth != null && auth.uid === $userId",
        
        // Validate user data structure
        ".validate": "newData.hasChildren(['username', 'email'])"
      }
    },
    
    // Stories node
    "stories": {
      // Anyone authenticated can read stories
      ".read": "auth != null",
      
      "$storyId": {
        // Only authenticated users can create stories
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
        
        // Validate story data structure
        ".validate": "newData.hasChildren(['userId', 'type', 'timestamp', 'expiresAt', 'views'])",
        
        // Validate story type
        "type": {
          ".validate": "newData.isString() && (newData.val() === 'TEXT' || newData.val() === 'IMAGE' || newData.val() === 'VIDEO')"
        },
        
        // Validate userId
        "userId": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        
        // Validate mediaUrl (required for IMAGE and VIDEO, optional for TEXT)
        "mediaUrl": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        
        // Validate text (optional, for TEXT stories)
        "text": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        
        // Validate caption (optional)
        "caption": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        
        // Validate backgroundColor (optional, for TEXT stories)
        "backgroundColor": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        
        // Validate timestamp
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        
        // Validate expiresAt
        "expiresAt": {
          ".validate": "newData.isNumber()"
        },
        
        // Validate views array
        "views": {
          ".validate": "newData.hasChildren() || !newData.exists()"
        }
      }
    },
    
    // Chats node
    "chats": {
      "$chatId": {
        // Members can read their chats
        ".read": "auth != null && (data.child('members').hasChild(auth.uid) || data.child('members').val().contains(auth.uid))",
        
        // Members can write to their chats
        ".write": "auth != null && (data.child('members').hasChild(auth.uid) || data.child('members').val().contains(auth.uid) || !data.exists())",
        
        // Messages in chat
        "messages": {
          "$messageId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    
    // Friend requests node
    "friendRequests": {
      "$requestId": {
        // Users can read requests sent to them or by them
        ".read": "auth != null && (data.child('fromUserId').val() === auth.uid || data.child('toUserId').val() === auth.uid)",
        
        // Users can create friend requests
        ".write": "auth != null && (!data.exists() || data.child('fromUserId').val() === auth.uid || data.child('toUserId').val() === auth.uid)"
      }
    },
    
    // Calls node
    "calls": {
      "$callId": {
        // Participants can read call data
        ".read": "auth != null && (data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid)",
        
        // Participants can write call data
        ".write": "auth != null && (data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid || !data.exists())"
      }
    }
  }
}
