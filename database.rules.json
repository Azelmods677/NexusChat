{
  "rules": {
    ".read": false,
    ".write": false,
    
    "users": {
      ".indexOn": ["username", "displayName"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['displayName', 'email'])",
        
        "fcmTokens": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        },
        
        "online": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === $uid"
        },
        
        "lastSeen": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    
    "userChats": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$chatId": {
          ".write": "auth != null && (auth.uid === $uid || root.child('chats').child($chatId).child('members').child(auth.uid).exists() || root.child('groups').child($chatId).child('members').child(auth.uid).exists())",
          ".validate": "newData.val() === true"
        }
      }
    },
    
    "chats": {
      "$chatId": {
        ".read": "auth != null && root.child('chats').child($chatId).child('members').child(auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || root.child('chats').child($chatId).child('members').child(auth.uid).exists())",
        
        "members": {
          "$memberId": {
            ".validate": "newData.val() === true"
          }
        },
        
        "messages": {
          ".indexOn": ["timestamp"],
          "$messageId": {
            ".read": "auth != null && root.child('chats').child($chatId).child('members').child(auth.uid).exists()",
            ".write": "auth != null && root.child('chats').child($chatId).child('members').child(auth.uid).exists()"
          }
        }
      }
    },
    
    "stories": {
      ".read": "auth != null",
      "$userId": {
        ".read": "auth != null",
        "$storyId": {
          ".write": "auth != null && auth.uid === $userId",
          ".validate": "newData.hasChildren(['storyId', 'userId', 'mediaUrl', 'mediaType', 'timestamp'])"
        }
      }
    },
    
    "stories_views": {
      "$storyId": {
        ".read": "auth != null",
        "$viewerId": {
          ".write": "auth != null && auth.uid === $viewerId"
        }
      }
    },

    "stories_reactions": {
      "$ownerId": {
        "$storyId": {
          ".read": "auth != null",
          "$reactorId": {
            ".write": "auth != null && auth.uid === $reactorId",
            ".validate": "newData.hasChildren(['emoji', 'timestamp'])"
          }
        }
      }
    },
    
    "calls": {
      ".indexOn": ["callerId", "receiverId"],
      "$callId": {
        ".read": "auth != null && (data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid)",
        ".write": "auth != null && (!data.exists() || data.child('callerId').val() === auth.uid || data.child('receiverId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['callerId', 'receiverId', 'callType'])"
      }
    },
    
    "friendRequests": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        "$requestId": {
          ".write": "auth != null && (!data.exists() || auth.uid === $userId || data.child('from').val() === auth.uid)"
        }
      }
    },

    "chat_settings": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "typing": {
      "$chatId": {
        "$userId": {
          ".read": "auth != null && root.child('chats').child($chatId).child('members').child(auth.uid).exists()",
          ".write": "auth != null && auth.uid === $userId"
        }
      }
    },

    "groups": {
      "$groupId": {
        ".read": "auth != null && root.child('groups').child($groupId).child('members').child(auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || root.child('groups').child($groupId).child('members').child(auth.uid).exists())"
      }
    },

    "group_settings": {
      "$groupId": {
        ".read": "auth != null && root.child('groups').child($groupId).child('members').child(auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || root.child('groups').child($groupId).child('members').child(auth.uid).exists())"
      }
    },

    "codeFiles": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "terminal": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "aiChats": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
